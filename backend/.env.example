# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ─── Database (PostgreSQL via Prisma) ──────────────────────────────────────────
# Local:   postgresql://postgres:password@localhost:5432/explorehimalaya
# Neon/Supabase: add ?sslmode=require at end
DATABASE_URL="postgresql://postgres:password@localhost:5432/explorehimalaya"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100            # requests per window

# ─── Firecrawl ─────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY="fc-your-api-key-here"
FIRECRAWL_BASE_URL="https://api.firecrawl.dev/v1"

# ─── AI / Anthropic (optional — for real AI summaries) ─────────────────────────
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# ─── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
# Set to a real S3/Cloudinary URL in production
UPLOAD_DEST="./uploads"

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug   # error | warn | info | http | debug
